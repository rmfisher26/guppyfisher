---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import SeriesNav from '../components/SeriesNav.astro';
import { getCollection } from 'astro:content';

const { frontmatter, slug } = Astro.props;

// Fetch sibling posts in the same series for SeriesNav
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const seriesPosts = allPosts.filter(p => p.data.series === frontmatter.series);

const seriesLabel: Record<string, string> = {
  concepts:    'Series 1 — Core Concepts',
  compiler:    'Series 2 — Compiler Internals',
  'deep-dives': 'Series 3 — Source Deep Dives',
};

const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});
---

<Base title={frontmatter.title} description={frontmatter.description}>
  <Header />

  <div class="back-link">
    <a href={import.meta.env.BASE_URL}>← All posts</a>
  </div>

  <article>
    <header class="post-header">
      <div class="post-series">
        {seriesLabel[frontmatter.series]} · Post #{frontmatter.seriesNumber}
      </div>

      <h1 class="post-title">{frontmatter.title}</h1>

      <div class="post-meta">
        <span>{formattedDate}</span>
        <span>~{frontmatter.readingTime} read</span>
        {frontmatter.prType && (
          <span class={`pr-type-chip pr-type-chip--${frontmatter.prType}`}>
            {frontmatter.prType === 'documentation' ? 'documentation' : frontmatter.prType}
          </span>
        )}
        {frontmatter.sourceFile && (
          <span class="source-chip">
            <code>{frontmatter.sourceFile}</code>
          </span>
        )}
      </div>
    </header>

    <!-- Series navigation (not shown for pull-requests) -->
    {frontmatter.series !== 'pull-requests' && (
      <SeriesNav
        posts={seriesPosts}
        currentSlug={slug}
        seriesName={seriesLabel[frontmatter.series]}
      />
    )}

    <!-- MDX content renders here -->
    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      <a href={import.meta.env.BASE_URL} class="back-btn">← Back to all posts</a>
    </footer>
  </article>
</Base>

<style>
  .back-link {
    max-width: 720px;
    margin: 2rem auto 0;
    padding: 0 2rem;
  }

  .back-link a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link a:hover { color: var(--accent); }

  article {
    max-width: 720px;
    margin: 0 auto 5rem;
    padding: 2rem 2rem 0;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--ink);
  }

  .post-series {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    color: var(--accent2);
  }

  .pr-link {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.25rem 0.65rem;
    margin: 1.5rem 0 0;
    transition: background 0.2s, color 0.2s;
  }

  .pr-link:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .post-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .pr-chip {
    background: rgba(0,200,150,0.12);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .pr-type-chip {
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .pr-type-chip--feature { background: rgba(0,200,150,0.15);  color: var(--accent); }
  .pr-type-chip--fix     { background: rgba(255,92,58,0.15);  color: #ff5c3a; }
  .pr-type-chip--doc     { background: rgba(250,204,21,0.15); color: #d4a800; }

  .source-chip code {
    font-size: 0.72rem;
    background: rgba(0,0,0,0.06);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .back-btn {
    font-family: 'Figtree', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-btn:hover { color: var(--accent); }
</style>
