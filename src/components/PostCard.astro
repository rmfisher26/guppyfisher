---
interface Props {
  title: string;
  description: string;
  series: string;
  seriesNumber: number;
  pubDate: Date;
  readingTime: string;
  prRef?: string;
  slug: string;
}

const { title, description, series, seriesNumber, pubDate, readingTime, prRef, slug } = Astro.props;

const seriesLabel: Record<string, string> = {
  concepts: 'Series 1 · Concepts',
  compiler: 'Series 2 · Compiler',
  'deep-dives': 'Series 3 · Deep Dives',
};

const stripeClass: Record<string, string> = {
  concepts: 's1',
  compiler: 's3',
  'deep-dives': 's4',
};

const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<a href={`${import.meta.env.BASE_URL}posts/${slug}`} class="post-card">
  <div class={`card-stripe ${stripeClass[series] ?? 's1'}`}></div>
  <div class="card-body">
    <div class="card-series">{seriesLabel[series]} · #{seriesNumber}</div>
    <div class="card-title">{title}</div>
    <div class="card-excerpt">{description}</div>
    <div class="card-footer">
      <span>{formattedDate} · {readingTime}</span>
      {prRef && <span class="pr-ref">{prRef}</span>}
      <span class="card-arrow">↗</span>
    </div>
  </div>
</a>

<style>
  .post-card {
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 14px;
    overflow: hidden;
    background: var(--card);
    cursor: pointer;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.05),
      0 1px 2px rgba(0, 0, 0, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    transform: translateY(-5px);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.10),
      0 4px 12px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.12);
  }

  .card-stripe { height: 4px; }
  .s1 { background: var(--accent); }
  .s2 { background: var(--accent2); }
  .s3 { background: #a78bfa; }
  .s4 { background: #facc15; }

  .card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-series {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .card-excerpt {
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.55;
    flex: 1;
    margin-bottom: 1rem;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    gap: 0.5rem;
  }

  .pr-ref {
    background: rgba(0,200,150,0.12);
    color: var(--accent);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }

  .card-arrow { transition: transform 0.2s; }
  .post-card:hover .card-arrow { transform: translate(3px, -3px); }
</style>
