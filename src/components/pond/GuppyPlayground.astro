---
// Guppy Playground Component — Interactive quantum program editor and simulator
// Based on guppy-playground.html, integrated into the Pond visualization

interface Props {
  class?: string;
}

const EXAMPLES = {
  bell: {
    filename: 'bell_pair.py',
    code: `from guppylang import guppy
from guppylang.std.quantum import qubit, h, cx, measure

@guppy
def bell_pair() -> tuple[bool, bool]:
    """Creates a Bell state and measures both qubits.
    
    Expected: |00⟩ and |11⟩ each with ~50% probability.
    """
    q0 = qubit()
    q1 = qubit()

    # Put q0 into superposition
    h(q0)

    # Entangle q0 and q1
    cx(q0, q1)

    # Measure both qubits
    m0 = measure(q0)
    m1 = measure(q1)

    return m0, m1

bell_pair.check()`,
    results: { '00': 512, '11': 512 },
    shots: 1024,
  },
  teleport: {
    filename: 'teleport.py',
    code: `from guppylang import guppy
from guppylang.std.builtins import owned
from guppylang.std.quantum import cx, h, measure, qubit, x, z

@guppy
def teleport(src: qubit @ owned, tgt: qubit) -> None:
    """Teleports the quantum state from src to tgt.
    
    Uses an ancilla qubit and classical feedforward corrections.
    """
    tmp = qubit()
    h(tmp)
    cx(tmp, tgt)
    cx(src, tmp)

    # Bell measurement with classical feedforward
    h(src)
    if measure(src):
        z(tgt)
    if measure(tmp):
        x(tgt)

teleport.check()`,
    results: { '0': 498, '1': 526 },
    shots: 1024,
  },
  deutsch: {
    filename: 'deutsch.py',
    code: `from guppylang import guppy
from guppylang.std.quantum import qubit, h, cx, measure

@guppy
def deutsch_constant(q: qubit, anc: qubit) -> tuple[qubit, qubit]:
    """Constant oracle: f(x) = 0 for all x. No-op."""
    return q, anc

@guppy
def deutsch_balanced(q: qubit, anc: qubit) -> tuple[qubit, qubit]:
    """Balanced oracle: f(x) = x. Applies CNOT."""
    cx(q, anc)
    return q, anc

@guppy
def deutsch(balanced: bool) -> bool:
    """Deutsch algorithm — determines if oracle is balanced or constant."""
    q   = qubit()
    anc = qubit()

    h(q)
    x(anc)
    h(anc)

    if balanced:
        q, anc = deutsch_balanced(q, anc)
    else:
        q, anc = deutsch_constant(q, anc)

    h(q)
    result = measure(q)
    _ = measure(anc)
    return result

deutsch.check()`,
    results: { '0': 1024 },
    shots: 1024,
  },
};

const { class: className = '' } = Astro.props;
---

<div class={`guppy-playground ${className}`}>
  <!-- Toolbar -->
  <div class="playground-toolbar">
    <div class="toolbar-left">
      <button class="btn btn-run" id="playground-run-btn">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        Run
      </button>
      
      <div class="toolbar-sep"></div>
      
      <div class="select-wrapper">
        <select class="toolbar-select" id="playground-example-select">
          {Object.entries(EXAMPLES).map(([key, example]) => (
            <option value={key}>{key === 'bell' ? 'Bell Pair' : key === 'teleport' ? 'Teleportation' : 'Deutsch Algorithm'}</option>
          ))}
        </select>
        <span class="select-arrow">▾</span>
      </div>
      
      <div class="toolbar-sep"></div>
      
      <div class="select-wrapper">
        <select class="toolbar-select" id="playground-shots-select">
          <option value="256">256 shots</option>
          <option value="1024" selected>1024 shots</option>
          <option value="4096">4096 shots</option>
        </select>
        <span class="select-arrow">▾</span>
      </div>
    </div>
    
    <div class="toolbar-right">
      <span class="version-badge">guppylang 0.21.10</span>
    </div>
  </div>
  
  <!-- Workspace -->
  <div class="playground-workspace">
    <!-- Editor Pane -->
    <div class="editor-pane">
      <div class="pane-header">
        <span class="pane-filename" id="playground-filename">bell_pair.py</span>
        <span class="pane-spacer"></span>
        <span class="pane-language">Guppy</span>
      </div>
      <div class="editor-area">
        <div class="line-numbers" id="playground-line-numbers"></div>
        <textarea 
          class="code-editor" 
          id="playground-code-editor" 
          spellcheck="false"
          autocomplete="off"
        ></textarea>
      </div>
    </div>
    
    <!-- Output Pane -->
    <div class="output-pane">
      <div class="output-tabs">
        <button class="output-tab active" data-tab="output">
          <span class="tab-dot teal"></span>
          Output
        </button>
        <button class="output-tab" data-tab="results">
          Results
        </button>
      </div>
      
      <div class="output-body">
        <div class="output-content active" id="playground-output">
          <div class="terminal" id="playground-terminal">
            <div class="term-line">
              <span class="term-prefix">$</span>
              <span class="term-text muted">Press ▶ Run or Ctrl+Enter to compile and simulate</span>
            </div>
          </div>
        </div>
        
        <div class="output-content" id="playground-results">
          <div class="chart-section" id="playground-chart">
            <div class="empty-state">
              <div class="empty-icon">◈</div>
              <div class="empty-title">No results yet</div>
              <div class="empty-desc">
                Run the program to see simulation results.<br><br>
                <span class="empty-kbd">Ctrl+Enter</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Status Bar -->
      <div class="output-status">
        <div class="status-item">
          <div class="status-dot"></div>
          <span>Ready</span>
        </div>
        <div class="status-spacer"></div>
        <span class="status-time"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .guppy-playground {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #0d1117;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
  }
  
  /* Toolbar */
  .playground-toolbar {
    height: 40px;
    background: #161b22;
    border-bottom: 1px solid #2a3444;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 8px;
  }
  
  .toolbar-left {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
  }
  
  .btn {
    height: 28px;
    padding: 0 12px;
    border-radius: 4px;
    border: none;
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.15s;
  }
  
  .btn-run {
    background: #00b4d8;
    color: #0a1628;
    font-weight: 600;
    padding: 0 16px;
  }
  
  .btn-run:hover {
    background: #0090ae;
  }
  
  .toolbar-sep {
    width: 1px;
    height: 18px;
    background: #2a3444;
    margin: 0 2px;
  }
  
  .select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  
  .toolbar-select {
    height: 28px;
    padding: 0 28px 0 10px;
    background: #1c2330;
    border: 1px solid #2a3444;
    border-radius: 4px;
    color: #8b98a8;
    font-family: inherit;
    font-size: 12px;
    cursor: pointer;
    appearance: none;
    outline: none;
  }
  
  .toolbar-select:hover {
    border-color: #3a4a60;
    color: #e6edf3;
  }
  
  .select-arrow {
    position: absolute;
    right: 8px;
    pointer-events: none;
    color: #4d5d70;
    font-size: 9px;
  }
  
  .toolbar-right {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .version-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #4d5d70;
    background: #0d1117;
    border: 1px solid #2a3444;
    border-radius: 100px;
    padding: 2px 8px;
  }
  
  /* Workspace */
  .playground-workspace {
    display: flex;
    height: 500px;
  }
  
  /* Editor Pane */
  .editor-pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    border-right: 1px solid #2a3444;
  }
  
  .pane-header {
    height: 34px;
    background: #161b22;
    border-bottom: 1px solid #2a3444;
    display: flex;
    align-items: center;
    padding: 0 14px;
    gap: 8px;
  }
  
  .pane-filename {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #8b98a8;
  }
  
  .pane-spacer {
    flex: 1;
  }
  
  .pane-language {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #4d5d70;
  }
  
  .editor-area {
    flex: 1;
    display: flex;
    overflow: hidden;
    position: relative;
  }
  
  .line-numbers {
    width: 52px;
    flex-shrink: 0;
    background: #0d1117;
    border-right: 1px solid #2a3444;
    padding: 16px 0;
    overflow: hidden;
    user-select: none;
  }
  
  .line-num {
    height: 20px;
    line-height: 20px;
    padding: 0 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #4d5d70;
    text-align: right;
  }
  
  .code-editor {
    flex: 1;
    background: #0d1117;
    color: #e6edf3;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 20px;
    padding: 16px;
    border: none;
    outline: none;
    resize: none;
    overflow: auto;
    tab-size: 4;
    white-space: pre;
  }
  
  .code-editor::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  
  .code-editor::-webkit-scrollbar-thumb {
    background: #2a3444;
    border-radius: 3px;
  }
  
  /* Output Pane */
  .output-pane {
    width: 420px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    background: #0d1117;
  }
  
  .output-tabs {
    height: 34px;
    background: #161b22;
    border-bottom: 1px solid #2a3444;
    display: flex;
    align-items: flex-end;
    padding: 0 12px;
    gap: 0;
  }
  
  .output-tab {
    height: 34px;
    padding: 0 12px;
    font-family: inherit;
    font-size: 11px;
    font-weight: 500;
    color: #4d5d70;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color 0.15s;
  }
  
  .output-tab:hover {
    color: #8b98a8;
  }
  
  .output-tab.active {
    color: #e6edf3;
    border-bottom-color: #00b4d8;
  }
  
  .tab-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  
  .tab-dot.teal {
    background: #00b4d8;
  }
  
  .output-body {
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  
  .output-content {
    display: none;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  
  .output-content.active {
    display: flex;
  }
  
  /* Terminal */
  .terminal {
    flex: 1;
    padding: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    overflow-y: auto;
  }
  
  .term-line {
    display: flex;
    gap: 10px;
  }
  
  .term-prefix {
    color: #4d5d70;
    flex-shrink: 0;
    user-select: none;
  }
  
  .term-text {
    flex: 1;
    color: #e6edf3;
  }
  
  .term-text.muted {
    color: #4d5d70;
  }
  
  /* Status Bar */
  .output-status {
    height: 28px;
    background: #161b22;
    border-top: 1px solid #2a3444;
    display: flex;
    align-items: center;
    padding: 0 14px;
    gap: 12px;
  }
  
  .status-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: #4d5d70;
  }
  
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4d5d70;
  }
  
  .status-spacer {
    flex: 1;
  }
  
  .status-time {
    font-size: 10px;
    color: #4d5d70;
    font-family: 'JetBrains Mono', monospace;
  }
  
  /* Empty State */
  .empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: #4d5d70;
    padding: 24px;
    text-align: center;
  }
  
  .empty-icon {
    font-size: 32px;
    opacity: 0.3;
  }
  
  .empty-title {
    font-size: 13px;
    font-weight: 500;
    color: #8b98a8;
  }
  
  .empty-desc {
    font-size: 11px;
    line-height: 1.6;
    max-width: 240px;
  }
  
  .empty-kbd {
    background: #161b22;
    border: 1px solid #2a3444;
    border-radius: 4px;
    padding: 2px 7px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #8b98a8;
  }
  
  .chart-section {
    flex: 1;
    overflow-y: auto;
  }
</style>

<script>
  // Initialize with Bell example
  const editor = document.getElementById('playground-code-editor') as HTMLTextAreaElement;
  const filenameEl = document.getElementById('playground-filename') as HTMLElement;
  const lineNumbersEl = document.getElementById('playground-line-numbers') as HTMLElement;
  const exampleSelect = document.getElementById('playground-example-select') as HTMLSelectElement;
  const runBtn = document.getElementById('playground-run-btn') as HTMLButtonElement;
  const terminal = document.getElementById('playground-terminal') as HTMLElement;
  const outputTab = document.querySelector('[data-tab="output"]') as HTMLButtonElement;
  const resultsTab = document.querySelector('[data-tab="results"]') as HTMLButtonElement;
  const outputContent = document.getElementById('playground-output') as HTMLElement;
  const resultsContent = document.getElementById('playground-results') as HTMLElement;
  
  // Load example code
  function loadExample(key: string) {
    const example = EXAMPLES[key as keyof typeof EXAMPLES];
    if (!example) return;
    
    editor.value = example.code;
    filenameEl.textContent = example.filename;
    updateLineNumbers();
  }
  
  // Update line numbers
  function updateLineNumbers() {
    const lines = editor.value.split('\n').length;
    lineNumbersEl.innerHTML = Array(lines)
      .fill(0)
      .map((_, i) => `<div class="line-num">${i + 1}</div>`)
      .join('');
  }
  
  // Tab switching
  outputTab.addEventListener('click', () => {
    outputTab.classList.add('active');
    resultsTab.classList.remove('active');
    outputContent.classList.add('active');
    resultsContent.classList.remove('active');
  });
  
  resultsTab.addEventListener('click', () => {
    resultsTab.classList.add('active');
    outputTab.classList.remove('active');
    resultsContent.classList.add('active');
    outputContent.classList.remove('active');
  });
  
  // Example selection
  exampleSelect.addEventListener('change', (e) => {
    loadExample((e.target as HTMLSelectElement).value);
  });
  
  // Editor input
  editor.addEventListener('input', updateLineNumbers);
  
  // Keyboard shortcut
  editor.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      runBtn.click();
    }
  });
  
  // Run button (placeholder)
  runBtn.addEventListener('click', () => {
    const line = document.createElement('div');
    line.className = 'term-line';
    line.innerHTML = `
      <span class="term-prefix">$</span>
      <span class="term-text success">✓ Compilation successful (placeholder)</span>
    `;
    terminal.appendChild(line);
    terminal.scrollTop = terminal.scrollHeight;
  });
  
  // Initialize
  loadExample('bell');
</script>
