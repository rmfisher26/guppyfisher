---
const base = import.meta.env.BASE_URL;
---
<footer>

  <div class="footer-col">
    <h4>On GitHub</h4>
    <a href="https://github.com/rmfisher26" target="_blank" rel="noopener">@rmfisher26 ↗</a>
    <a href="https://github.com/CQCL/guppylang" target="_blank" rel="noopener">guppylang repo ↗</a>

  </div>
  <div class="footer-col">
    <h4>About</h4>
    <a href={`${base}about`}>About</a>
    <a href="https://www.linkedin.com/in/rmfisher26/" target="_blank" rel="noopener">LinkedIn ↗</a>
  </div>
</footer>

<style>
  footer {
    border-top: 2px solid var(--ink);
    padding: 2.5rem 2rem;
    display: flex;
    justify-content: center;
    gap: 6rem;
    max-width: 900px;
    margin: 0 auto;
    font-size: 0.85rem;
  }

  .footer-col h4 {
    font-family: 'Figtree', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .footer-col a {
    display: block;
    color: var(--muted);
    text-decoration: none;
    font-family: 'Figtree', sans-serif;
    font-size: 0.75rem;
    line-height: 2;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--accent); }

  @media (max-width: 700px) {
    footer { gap: 3rem; }
  }
</style>
