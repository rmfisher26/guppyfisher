---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { flatEntries, typeColors } from '../data/logEntries';
import { seriesLabel } from '../data/series';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const conceptsPosts      = sorted.filter(p => p.data.series === 'concepts');
const compilerPosts      = sorted.filter(p => p.data.series === 'compiler');
const deepDivesPosts     = sorted.filter(p => p.data.series === 'deep-dives');
const pullRequestsPosts  = sorted.filter(p => p.data.series === 'pull-requests');

const featured = pullRequestsPosts[0];
const recentPRs = pullRequestsPosts.filter(p => p.slug !== featured?.slug).slice(0, 3);

const featuredDate = featured?.data.pubDate.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC',
});

const recentActivity = flatEntries.slice(0, 3);
---

<Base title="Guppyfisher">
  <Header />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-eyebrow">welcome</div>
    <h1>Casting a line into <em><span class="hero-guppy">Guppy's</span></em> depths</h1>
    <p class="hero-desc">
      An ongoing log of everything I'm discovering about <a href="https://docs.quantinuum.com/guppy/" target="_blank" rel="noopener">Guppy</a> —
      a quantum programming language built by <a href="https://www.quantinuum.com/" target="_blank" rel="noopener">Quantinuum</a>.
    </p>

  </section>

  <hr class="section-rule" />

  <!-- RECENT ACTIVITY -->
  <div class="recent-activity">
    <div class="section-heading">
      <h2>Recent Activity</h2>
      <div class="rule"></div>
      <a href={`${base}log`} class="view-log-link">view log →</a>
    </div>
    <div class="activity-list">
      {recentActivity.map((item) => (
        <div class="activity-item" style={`--entry-color: ${typeColors[item.type] ?? 'var(--muted)'}`}>
          <div class="timeline-dot" />
          <div class="activity-body">
            <div class="activity-meta">
              <span class="timeline-type-pill">{item.label}</span>
              <span class="activity-date">{item.date}</span>
              {item.link && (
                <a class="activity-link" href={item.link}>{item.linkLabel ?? 'view'}</a>
              )}
            </div>
            <div class="activity-title">{item.title}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <hr class="section-rule" />

  <!-- FEATURED POST -->
  {featured && (
    <>
      <div class="section-heading">
        <h2>Featured</h2>
        <div class="rule"></div>
      </div>

      <div class="featured">
        <a href={`${base}posts/${featured.slug}`} class="featured-card">
          <div class="featured-visual">
            <div class="circuit-viz">
              <svg viewBox="0 0 280 180" aria-hidden="true" class="circuit-svg">
                <!-- Qubit wire labels -->
                <text x="6" y="48" class="q-label">q[0]</text>
                <text x="6" y="98" class="q-label">q[1]</text>
                <text x="6" y="148" class="q-label">q[2]</text>

                <!-- Qubit wires -->
                <line x1="44" y1="45" x2="265" y2="45" class="wire"/>
                <line x1="44" y1="95" x2="265" y2="95" class="wire"/>
                <line x1="44" y1="145" x2="265" y2="145" class="wire"/>

                <!-- H gate q[0] -->
                <rect x="55" y="33" width="26" height="24" class="gate gate-h"/>
                <text x="68" y="50" class="gate-label">H</text>

                <!-- H gate q[1] -->
                <rect x="55" y="83" width="26" height="24" class="gate gate-h"/>
                <text x="68" y="100" class="gate-label">H</text>

                <!-- CNOT: control q[0], target q[1] -->
                <line x1="115" y1="45" x2="115" y2="95" class="cnot-line"/>
                <circle cx="115" cy="45" r="5" class="cnot-ctrl"/>
                <circle cx="115" cy="95" r="10" class="cnot-target"/>
                <line x1="115" y1="85" x2="115" y2="105" class="cnot-cross"/>
                <line x1="105" y1="95" x2="125" y2="95" class="cnot-cross"/>

                <!-- Rz gate q[2] -->
                <rect x="100" y="133" width="30" height="24" class="gate gate-rz"/>
                <text x="115" y="150" class="gate-label">Rz</text>

                <!-- CNOT: control q[1], target q[2] -->
                <line x1="165" y1="95" x2="165" y2="145" class="cnot-line"/>
                <circle cx="165" cy="95" r="5" class="cnot-ctrl"/>
                <circle cx="165" cy="145" r="10" class="cnot-target"/>
                <line x1="165" y1="135" x2="165" y2="155" class="cnot-cross"/>
                <line x1="155" y1="145" x2="175" y2="145" class="cnot-cross"/>

                <!-- Measure gates -->
                <rect x="215" y="33" width="32" height="24" class="gate gate-m"/>
                <text x="231" y="50" class="gate-label">M</text>
                <rect x="215" y="83" width="32" height="24" class="gate gate-m"/>
                <text x="231" y="100" class="gate-label">M</text>
                <rect x="215" y="133" width="32" height="24" class="gate gate-m"/>
                <text x="231" y="150" class="gate-label">M</text>

                <!-- Double-line (classical) after measure -->
                <line x1="247" y1="43" x2="265" y2="43" class="classical"/>
                <line x1="247" y1="47" x2="265" y2="47" class="classical"/>
                <line x1="247" y1="93" x2="265" y2="93" class="classical"/>
                <line x1="247" y1="97" x2="265" y2="97" class="classical"/>
                <line x1="247" y1="143" x2="265" y2="143" class="classical"/>
                <line x1="247" y1="147" x2="265" y2="147" class="classical"/>
              </svg>
              <div class="circuit-comment">// quantum circuit — 3 qubits</div>
            </div>
          </div>
          <div class="featured-content">
            <div>
              <div class="feat-series-row">
                <div class="feat-series">{seriesLabel[featured.data.series]} · Post #{featured.data.seriesNumber}</div>
                {featured.data.prType && <span class={`pr-badge pr-badge--${featured.data.prType}`}>{featured.data.prType}</span>}
              </div>
              <div class="feat-title">{featured.data.title}</div>
              <div class="feat-excerpt">{featured.data.description}</div>
            </div>
            <div>
              <div class="feat-meta">
                <span>{featuredDate}</span>
                <span>~{featured.data.readingTime} read</span>
              </div>
              <span class="read-btn">Read more →</span>
            </div>
          </div>
        </a>
      </div>
    </>
  )}

  <!-- RECENT PULL REQUESTS -->
  {recentPRs.length > 0 && (
    <div class="recent-prs">
      <div class="section-heading">
        <h2>Recent Pull Requests</h2>
        <div class="rule"></div>
        <a href={`${base}pull-requests`} class="view-log-link">view all →</a>
      </div>
      <div class="recent-pr-grid">
        {recentPRs.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            series={post.data.series}
            seriesNumber={post.data.seriesNumber}
            pubDate={post.data.pubDate}
            readingTime={post.data.readingTime}
            prRef={post.data.prRef}
            prType={post.data.prType}
            slug={post.slug}
          />
        ))}
      </div>
    </div>
  )}

</Base>

<style>
  /* HERO */
  .hero {
    padding: 2.5rem 2rem 2rem;
    max-width: 900px;
    margin: 0 auto;
    animation: fadeUp 0.6s ease both;
  }

  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--accent2);
    margin-bottom: 2rem;
  }

  .hero-guppy {
    font-family: 'Figtree', sans-serif;
    font-style: normal;
    color: var(--accent);
    font-weight: 600;

  }

  h1 em {
    font-style: italic;
    font-family: 'Lora', serif;
    font-weight: 400;
    color: var(--accent2);
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .hero-desc a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .hero-desc a:hover {
    border-bottom-color: var(--accent);
  }

  .hero-pipeline {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    background: var(--code-bg);
    padding: 1rem 1.5rem;
    border-radius: 6px;
    border-left: 3px solid var(--accent);
    overflow-x: auto;
    white-space: nowrap;
  }

  .pipe-step  { color: var(--code-fg); }
  .pipe-arrow { color: var(--accent2); margin: 0 0.5rem; opacity: 0.7; }
  .pipe-active {
    color: var(--ink);
    background: var(--accent);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
  }

  .section-rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem auto;
    max-width: 900px;
  }

  /* SECTION HEADING */
  .section-heading {
    max-width: 900px;
    margin: 0 auto 2.5rem;
    padding: 0 2rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .section-heading h2 {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .rule { flex: 1; height: 1px; background: var(--border); }

  /* FEATURED CARD */
  .featured {
    max-width: 900px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
    animation: fadeUp 0.6s ease 0.1s both;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.05),
      0 1px 2px rgba(0, 0, 0, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .featured-card:hover {
    transform: translateY(-5px);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.10),
      0 4px 12px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.12);
  }

  .featured-visual {
    background: var(--code-bg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 320px;
    position: relative;
    overflow: hidden;
  }

  /* QUANTUM CIRCUIT */
  .circuit-viz {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .circuit-svg {
    width: 100%;
    max-width: 280px;
  }

  .circuit-svg .q-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    fill: var(--muted);
  }

  .circuit-svg .wire {
    stroke: var(--accent);
    stroke-width: 1.5;
    stroke-opacity: 0.35;
  }

  .circuit-svg .classical {
    stroke: var(--accent2);
    stroke-width: 1;
    stroke-opacity: 0.5;
  }

  .circuit-svg .gate-h {
    fill: rgba(0, 200, 150, 0.12);
    stroke: var(--accent);
    stroke-width: 1.2;
    rx: 3;
  }

  .circuit-svg .gate-rz {
    fill: rgba(124, 92, 191, 0.15);
    stroke: #a78bfa;
    stroke-width: 1.2;
    rx: 3;
  }

  .circuit-svg .gate-m {
    fill: rgba(255, 92, 58, 0.33);
    stroke: #a35545;
    stroke-width: 2;
    rx: 3;
  }

  .circuit-svg .gate-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    fill: #ffffff;
    text-anchor: middle;
    dominant-baseline: middle;
  }

  .circuit-svg .cnot-line {
    stroke: var(--accent);
    stroke-width: 1.2;
    stroke-opacity: 0.6;
  }

  .circuit-svg .cnot-ctrl {
    fill: var(--accent);
    stroke: none;
  }

  .circuit-svg .cnot-target {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.5;
  }

  .circuit-svg .cnot-cross {
    stroke: var(--accent);
    stroke-width: 1.5;
  }

  .circuit-comment {
    margin-top: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: #c4ced9;
  }

  .featured-content {
    background: var(--card);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .feat-series-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .feat-series {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 0;
  }

  .feat-title {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--accent2);
  }

  .feat-excerpt {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .feat-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .read-btn {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ink);
    color: var(--paper);
    font-family: 'Figtree', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.7rem 1.4rem;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
  }

  .featured-card:hover .read-btn {
    background: var(--accent);
    color: var(--ink);
  }

  /* RECENT PULL REQUESTS */
  .recent-prs {
    max-width: 900px;
    margin: 0 auto 3rem;
    padding: 0 2rem;
    animation: fadeUp 0.6s ease 0.15s both;
  }

  .recent-pr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  /* RECENT ACTIVITY */
  .recent-activity {
    max-width: 900px;
    margin: 0 auto 3rem;
    padding: 0 2rem;
    animation: fadeUp 0.6s ease 0.15s both;
  }

  .recent-activity .section-heading,
  .recent-prs .section-heading {
    padding: 0;
    max-width: unset;
    margin-left: 0;
    margin-right: 0;
  }

  .section-heading .view-log-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .section-heading .view-log-link:hover {
    color: var(--accent);
  }

  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 2px solid var(--border);
    padding-left: 1.5rem;
    margin-top: 1.5rem;
  }

  .activity-item {
    position: relative;
    display: flex;
  }

  .activity-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .activity-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .activity-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
  }

  .activity-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px dashed var(--border);
    transition: color 0.15s, border-color 0.15s;
  }

  .activity-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .activity-title {
    font-family: 'Figtree', sans-serif;
    font-size: 0.95rem;
    color: var(--ink);
    line-height: 1.35;
  }

  @media (max-width: 700px) {
    .featured-card { grid-template-columns: 1fr; }
    .recent-pr-grid { grid-template-columns: 1fr; }
  }
</style>
