---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const seriesMeta = [
  {
    key: 'concepts',
    number: '01',
    label: 'Core Concepts',
    description: 'Discussions from my own analysis and study of Guppy and how it works (as far as I know)',
    color: 'var(--accent)',
  },
  {
    key: 'deep-dives',
    number: '02',
    label: 'Source Deep Dives',
    description: 'Explorations of various code samples to study further',
    color: '#facc15',
  },
];

function postsForSeries(key: string) {
  return allPosts
    .filter(p => p.data.series === key)
    .sort((a, b) => key === 'pull-requests'
      ? b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
      : a.data.seriesNumber - b.data.seriesNumber
    );
}
---

<Base title="Notes" description="All notes on Guppyfisher.">
  <Header />

  <main class="series-page">

    <div class="page-header">
      <div class="eyebrow">reading paths</div>
      <h1>Notes</h1>
      <p class="subtitle">Collections of my notes from my deep dives into <a href="https://docs.quantinuum.com/guppy/" target="_blank" rel="noopener">Guppy</a></p>
    </div>

    {seriesMeta.map((s) => {
      const posts = postsForSeries(s.key);
      return (
        <section class="series-section" style={`--series-color: ${s.color}`}>
          <div class="series-header">
            <span class="series-number">{s.number}</span>
            <div>
              <h2 class="series-title">{s.label}</h2>
              <p class="series-desc">{s.description}</p>
            </div>
          </div>

          {s.key === 'pull-requests' ? (
            posts.length === 0 ? (
              <div class="empty">
                <span class="empty-icon">⟳</span>
                <span>Posts coming soon</span>
              </div>
            ) : (
              <div class="post-card-grid">
                {posts.map((post) => (
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    series={post.data.series}
                    seriesNumber={post.data.seriesNumber}
                    pubDate={post.data.pubDate}
                    readingTime={post.data.readingTime}
                    prRef={post.data.prRef}
                    prType={post.data.prType}
                    slug={post.slug}
                  />
                ))}
              </div>
            )
          ) : (
            <div class="post-list">
              {posts.length === 0 ? (
                <div class="empty">
                  <span class="empty-icon">⟳</span>
                  <span>Posts coming soon</span>
                </div>
              ) : (
                posts.map((post) => (
                  <a href={`${base}posts/${post.slug}`} class="post-row">
                    <span class="post-num">#{post.data.seriesNumber}</span>
                    <div class="post-info">
                      <div class="post-title">{post.data.title}</div>
                      <div class="post-excerpt">{post.data.description}</div>
                    </div>
                    <div class="post-meta">
                      <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
                      <span>{post.data.readingTime}</span>
                      {post.data.prRef && <span class="pr-chip">{post.data.prRef}</span>}
                    </div>
                    <span class="post-arrow">↗</span>
                  </a>
                ))
              )}
            </div>
          )}
        </section>
      );
    })}

  </main>
</Base>

<style>
  .series-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 5rem 0 3.5rem;
    animation: fadeUp 0.5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--accent2);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--muted);
    font-style: italic;
  }

  .subtitle a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .subtitle a:hover {
    border-bottom-color: var(--accent);
  }

  /* ── SERIES SECTION ── */
  .series-section {
    border-left: 3px solid var(--series-color);
    padding-left: 2rem;
    margin-bottom: 3.5rem;
    animation: fadeUp 0.5s ease both;
  }

  .series-section:nth-child(2) { animation-delay: 0.05s; }
  .series-section:nth-child(3) { animation-delay: 0.10s; }
  .series-section:nth-child(4) { animation-delay: 0.15s; }

  .series-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .series-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--series-color);
    background: color-mix(in srgb, var(--series-color) 12%, transparent);
    padding: 0.3rem 0.5rem;
    border-radius: 3px;
    white-space: nowrap;
    margin-top: 0.2rem;
    letter-spacing: 0.05em;
  }

  .series-title {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .series-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 580px;
  }

  /* ── POST LIST ── */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto 1.5rem;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1rem 1rem 0;
    border-top: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
    border-radius: 0 4px 4px 0;
  }

  .post-row:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-row:hover {
    background: color-mix(in srgb, var(--series-color) 5%, transparent);
    padding-left: 0.5rem;
  }

  .post-row:hover .post-arrow {
    transform: translate(2px, -2px);
    color: var(--series-color);
  }

  .post-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--series-color);
    text-align: right;
    opacity: 0.8;
  }

  .post-title {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.2rem;
  }

  .post-excerpt {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .pr-chip {
    background: color-mix(in srgb, var(--series-color) 15%, transparent);
    color: var(--series-color);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }

  .post-arrow {
    font-size: 1rem;
    color: var(--muted);
    transition: transform 0.2s ease, color 0.2s ease;
    text-align: center;
  }

  /* ── PULL REQUEST CARD GRID ── */
  .post-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 640px) {
    .post-card-grid { grid-template-columns: 1fr; }
  }

  /* ── EMPTY STATE ── */
  .empty {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .empty-icon {
    font-size: 1rem;
    opacity: 0.5;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .post-row {
      grid-template-columns: 2rem 1fr 1.5rem;
    }

    .post-meta { display: none; }

    .series-header { gap: 0.75rem; }
  }
</style>
