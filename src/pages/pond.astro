---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import PipelineController from '../components/pond/PipelineController';
import GuppyPlayground from '../components/pond/GuppyPlayground.astro';
---

<Base
  title="Pond"
  description="Trace a Guppy quantum program through the full Quantinuum stack: HUGR IR → TKET → Selene emulation."
>
  <Header />

  <main class="pond-page">

    <div class="page-header">
      <div class="eyebrow">pipeline visualizer</div>
      <h1>Pond</h1>
      <p class="subtitle">Trace a Guppy program through the full Quantinuum stack — HUGR IR → TKET → Selene emulation.</p>
    </div>

    <div class="pond-wrapper">
      <PipelineController client:load initialProgram="bell" />
    </div>

    <!-- Guppy Playground Section -->
    <div class="playground-section">
      <div class="section-header">
        <h2>Guppy Playground</h2>
        <p>Try out Guppy code interactively — edit, compile, and simulate quantum programs right in your browser.</p>
      </div>
      <GuppyPlayground />
    </div>

  </main>
</Base>

<style>
  .pond-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 5rem 0 3.5rem;
    animation: fadeUp 0.5s ease both;
  }

  h1 {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--accent2);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--muted);
    font-style: italic;
  }

  /* ── PIPELINE ── */
  .pond-wrapper {
    animation: fadeUp 0.5s ease both;
    animation-delay: 0.1s;
    padding-bottom: 60px;
  }

  /*
   * Pond CSS variables are scoped here so they don't leak into the rest of
   * the site. The pond components use var(--bg), var(--green), etc. which
   * cascade down from this wrapper.
   */
  .pond-wrapper {
    --bg:      #ffffff;
    --bg1:     #ffffff;
    --bg2:     #f4f5f7;
    --bg3:     #eaecef;
    --border:  #dfdddb;
    --text:    #0d0f14;
    --muted:   #6b7280;
    --green:   #1a6b4a;
    --green-l: #2a9d6a;
    --blue:    #4a80c8;
    --red:     #c84040;
    --purple:  #a040c8;
    --gold:    #b8860b;
    --font-body: 'Figtree', sans-serif;
    --font-mono: 'Figtree', sans-serif;
  }

  /* Syntax highlight tokens — tuned for light backgrounds */
  :global(.hl-kw)  { color: #c0392b; }
  :global(.hl-dec) { color: #b8860b; }
  :global(.hl-typ) { color: #1a8a5a; }

  /* Playground Section */
  .playground-section {
    margin-top: 60px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
    animation: fadeUp 0.5s ease both;
    animation-delay: 0.2s;
  }

  .section-header {
    margin-bottom: 24px;
  }

  .section-header h2 {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--accent2);
    margin-bottom: 8px;
  }

  .section-header p {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
  }
  :global(.hl-fn)  { color: #2a70b0; }
  :global(.hl-str) { color: #3a7a20; }
  :global(.hl-com) { color: #8a8a9a; }
  :global(.hl-num) { color: #b06020; }

  :global(.hl-jkey) { color: #2a70b0; }
  :global(.hl-jstr) { color: #3a7a20; }
  :global(.hl-jnum) { color: #b06020; }
  :global(.hl-jkw)  { color: #c0392b; }
</style>
