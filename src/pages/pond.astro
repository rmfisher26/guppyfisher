---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import PipelineController from '../components/pond/PipelineController';
---

<Base
  title="Pond"
  description="Trace a Guppy quantum program through the full Quantinuum stack: HUGR IR → TKET → Selene emulation."
>
  <Header />

  <main class="pond-page">

    <div class="page-header">
      <div class="eyebrow">pipeline visualizer</div>
      <h1>Pond</h1>
      <p class="subtitle">Trace a Guppy program through the full Quantinuum stack — HUGR IR → TKET → Selene emulation.</p>
    </div>

    <div class="pond-wrapper">
      <PipelineController client:load initialProgram="bell" />
    </div>

  </main>
</Base>

<style>
  .pond-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 5rem 0 3.5rem;
    animation: fadeUp 0.5s ease both;
  }

  h1 {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--accent2);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--muted);
    font-style: italic;
  }

  /* ── PIPELINE ── */
  .pond-wrapper {
    animation: fadeUp 0.5s ease both;
    animation-delay: 0.1s;
    padding-bottom: 60px;
  }

  /*
   * Pond CSS variables are scoped here so they don't leak into the rest of
   * the site. The pond components use var(--bg), var(--green), etc. which
   * cascade down from this wrapper.
   */
  .pond-wrapper {
    --bg:      #07080c;
    --bg1:     #0d0f16;
    --bg2:     #12151f;
    --bg3:     #181c28;
    --border:  #1e2436;
    --text:    #d8e0f0;
    --muted:   #505878;
    --green:   #1a6b4a;
    --green-l: #2a9d6a;
    --blue:    #4a80c8;
    --red:     #c84040;
    --purple:  #a040c8;
    --gold:    #c8a040;
    --font-body: 'Outfit', sans-serif;
    --font-mono: 'Fira Code', monospace;
  }

  /* Syntax highlight tokens used by pond components */
  :global(.hl-kw)  { color: #f08090; font-style: italic; }
  :global(.hl-dec) { color: #d0b050; }
  :global(.hl-typ) { color: #50c898; }
  :global(.hl-fn)  { color: #78b8e0; }
  :global(.hl-str) { color: #88c868; }
  :global(.hl-com) { color: #3a4050; font-style: italic; }
  :global(.hl-num) { color: #e0a060; }

  :global(.hl-jkey) { color: #78b8e0; }
  :global(.hl-jstr) { color: #88c868; }
  :global(.hl-jnum) { color: #e0a060; }
  :global(.hl-jkw)  { color: #f08090; }
</style>
