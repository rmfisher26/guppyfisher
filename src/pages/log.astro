---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import { entries, typeColors, flatEntries } from '../data/logEntries';

const ITEMS_PER_PAGE = 10;

const flat = flatEntries;

// Chunk into pages of ITEMS_PER_PAGE
const chunks: (typeof flat)[] = [];
for (let i = 0; i < flat.length; i += ITEMS_PER_PAGE) {
  chunks.push(flat.slice(i, i + ITEMS_PER_PAGE));
}

// Reconstruct week/day grouping per page
type ReconPage = { week: string; days: { date: string; items: typeof flat }[] }[];
const pages: ReconPage[] = chunks.map(chunk => {
  const result: ReconPage = [];
  for (const item of chunk) {
    let weekEntry = result.find(w => w.week === item.weekLabel);
    if (!weekEntry) { weekEntry = { week: item.weekLabel, days: [] }; result.push(weekEntry); }
    let dayEntry = weekEntry.days.find(d => d.date === item.date);
    if (!dayEntry) { dayEntry = { date: item.date, items: [] }; weekEntry.days.push(dayEntry); }
    dayEntry.items.push(item);
  }
  return result;
});

const totalPages = pages.length;
---

<Base title="Log">
  <Header />

  <main class="log-main">
    <div class="page-header">
      <div class="log-eyebrow">status update</div>
      <h1>Log</h1>
      <p class="log-desc">
        A running record of what I'm reading, building, and figuring out — day by day.
      </p>
    </div>

    <!-- Timeline -->
    <div class="timeline" id="timeline">
      {pages.map((pageWeeks, pageIndex) => (
        <div class="log-page" data-page={pageIndex}>
          {pageWeeks.map((week) => (
            <section class="week-block">
              <div class="week-label">{week.week}</div>
              <div class="week-entries">
                {week.days.map((day) => (
                  <div class="day-group">
                    <div class="day-date">{day.date}</div>
                    <div class="day-items">
                      {day.items.map((item) => (
                        <div class="log-entry" style={`--entry-color: ${typeColors[item.type] ?? 'var(--muted)'}`}>
                          <div class="entry-dot" />
                          <div class="entry-body">
                            <div class="entry-meta">
                              <span class="entry-type">{item.label}</span>
                              {item.link && (
                                <a class="entry-link" href={item.link}>{item.linkLabel ?? 'view'}</a>
                              )}
                            </div>
                            <div class="entry-title">{item.title}</div>
                            {item.body && <p class="entry-text">{item.body}</p>}
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      ))}
    </div>

    <!-- Pagination controls -->
    <div class="pagination" id="pagination">
      <button class="page-btn" id="prev-btn" aria-label="Previous page" disabled>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Prev
      </button>
      <span class="page-indicator" id="page-indicator">Page 1 of {totalPages}</span>
      <button class="page-btn" id="next-btn" aria-label="Next page">
        Next
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </main>
</Base>

<style>
  .log-main {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── HEADER ── */
  .page-header {
    animation: fadeUp 0.5s ease both;
  }

  .timeline {
    animation: fadeUp 0.5s ease 0.15s both;
  }

  .pagination {
    animation: fadeUp 0.5s ease 0.25s both;
  }

  .log-header { margin-bottom: 2.5rem; }

  .log-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .log-eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: 'Figtree', sans-serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--accent2);
    margin-bottom: 1rem;
  }

  .log-desc {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.6;
    padding-bottom: 2rem;
    font-style:italic;
  }

  /* ── WEEK BLOCK ── */
  .week-block {
    margin-bottom: 3.5rem;
  }

  .log-page[hidden] { display: none; }
  .week-block[hidden] { display: none; }

  .week-label {
    font-family: 'Figtree', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.75rem;
  }

  /* ── DAY GROUP ── */
  .day-group {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 0 1.5rem;
    margin-bottom: 1.5rem;
  }

  .day-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    padding-top: 0.35rem;
    text-align: right;
    line-height: 1.4;
  }

  /* ── ENTRIES ── */
  .day-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 2px solid var(--border);
    padding-left: 1.5rem;
  }

  .log-entry {
    position: relative;
    display: flex;
  }

  .entry-dot {
    position: absolute;
    left: -1.6rem;
    top: 0.45rem;
    transform: translateX(calc(-50% + 1px));
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--entry-color);
    border: 2px solid var(--paper);
    box-shadow: 0 0 0 1.5px var(--entry-color);
    flex-shrink: 0;
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-bottom: 0.25rem;
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .entry-type {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--entry-color);
    background: color-mix(in srgb, var(--entry-color) 10%, transparent);
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
  }

  .entry-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px dashed var(--border);
    transition: color 0.15s, border-color 0.15s;
  }

  .entry-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .entry-title {
    font-family: 'Figtree', sans-serif;
    font-size: 0.95rem;
    color: var(--ink);
    line-height: 1.35;
  }

  .entry-text {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── PAGINATION ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }

  .page-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Figtree', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink);
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--paper);
  }

  .page-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .page-indicator {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* ── MOBILE ── */
  @media (max-width: 600px) {
    .day-group {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .day-date {
      text-align: left;
      padding-top: 0;
    }
  }
</style>

<script>
  const logPages  = Array.from(document.querySelectorAll<HTMLElement>('.log-page'));
  const prevBtn   = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn   = document.getElementById('next-btn') as HTMLButtonElement;
  const indicator = document.getElementById('page-indicator')!;

  const totalPages = logPages.length;
  let currentPage  = 0;

  function goToPage(page: number) {
    currentPage = Math.max(0, Math.min(page, totalPages - 1));

    logPages.forEach((p, i) => { p.hidden = i !== currentPage; });

    prevBtn.disabled = currentPage === 0;
    nextBtn.disabled = currentPage === totalPages - 1;
    indicator.textContent = `Page ${currentPage + 1} of ${totalPages}`;
  }

  const pageHeader = document.querySelector<HTMLElement>('.page-header')!;

  prevBtn.addEventListener('click', () => { goToPage(currentPage - 1); pageHeader.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
  nextBtn.addEventListener('click', () => { goToPage(currentPage + 1); pageHeader.scrollIntoView({ behavior: 'smooth', block: 'start' }); });

  goToPage(0);
</script>
